{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "streamlit-app",
      "runtimeExecutable": "py",
      "runtimeArgs": ["-3.12", "-m", "streamlit", "run", "app.py"],
      "port": 8501
    },
    {
      "name": "hiring-tool",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd HiringTool && py -3.12 -m streamlit run app.py --server.port 8502"],
      "port": 8502
    }
  ]
}